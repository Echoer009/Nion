<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <!-- 悬浮窗权限：在 App 后台时显示提醒悬浮卡片 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- 电池优化白名单权限：跳转系统电池优化设置页，避免省电策略杀后台导致闹钟丢失 -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- 前台 Service 权限：Android 9+ 保活悬浮窗 Service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 14+ specialUse 前台 Service 必须声明此权限，否则 startForeground 会抛 SecurityException -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- 震动权限：悬浮窗提醒/专注完成时震动反馈 -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- 位置权限：天气功能需要 GPS 定位获取用户所在城市 -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Phone Agent 需要查询所有已安装应用来启动目标 App（Android 11+ Package Visibility）
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" /> -->

    <application
        android:name=".NionApp"
        android:allowBackup="false"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Nion">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Nion">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 提醒闹钟触发接收器，处理 AlarmManager 到点触发 -->
        <receiver
            android:name=".reminder.ReminderReceiver"
            android:exported="false" />

        <!-- 通知栏 Action 按钮点击接收器，处理「开始做了/等5分钟/今天算了」 -->
        <receiver
            android:name=".reminder.ReminderActionReceiver"
            android:exported="false" />

        <!-- 情景问候闹钟触发接收器 -->
        <receiver
            android:name=".reminder.GreetingReceiver"
            android:exported="false" />

        <!-- 悬浮提醒 Service：在 App 后台时通过 WindowManager 显示悬浮卡片 -->
        <service
            android:name=".reminder.ReminderFloatingService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- 问候悬浮窗 Service：在 App 后台时通过 WindowManager 显示问候悬浮卡片 -->
        <service
            android:name=".reminder.GreetingFloatingService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- 天气预警悬浮窗 Service：在 App 后台时通过 WindowManager 显示天气预警悬浮卡片 -->
        <service
            android:name=".reminder.WeatherAlertFloatingService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- 开机重调度接收器，设备重启后重新注册所有闹钟 -->
        <receiver
            android:name=".reminder.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- ===== Phone Agent 功能暂未成熟，以下服务和接收器全部注释禁用 =====

        Phone Agent 无障碍服务 —— 提供截图、手势执行、全局操作等能力
             用于 Phone Agent 子循环，让 AI 能够操控手机界面
        <service
            android:name=".ui.companion.phoneagent.PhoneAgentService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/phone_agent_service_config" />
        </service>

        Phone Agent 悬浮窗 Service —— Agent 执行手机操作时实时显示思考与操作过程
        <service
            android:name=".ui.companion.phoneagent.PhoneAgentFloatingService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        定时手机任务闹钟触发接收器 —— AlarmManager 到点时发送等待确认通知
        <receiver
            android:name=".reminder.PhoneAutomationReceiver"
            android:exported="false" />
        ===== Phone Agent 禁用区结束 ===== -->
    </application>

</manifest>
