<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <!-- 悬浮窗权限：在 App 后台时显示提醒悬浮卡片 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- 前台 Service 权限：Android 9+ 保活悬浮窗 Service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 14+ specialUse 前台 Service 必须声明此权限，否则 startForeground 会抛 SecurityException -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- 位置权限：天气功能需要 GPS 定位获取用户所在城市 -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:name=".NionApp"
        android:allowBackup="false"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Nion">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Nion">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 提醒闹钟触发接收器，处理 AlarmManager 到点触发 -->
        <receiver
            android:name=".reminder.ReminderReceiver"
            android:exported="false" />

        <!-- 通知栏 Action 按钮点击接收器，处理「开始做了/等5分钟/今天算了」 -->
        <receiver
            android:name=".reminder.ReminderActionReceiver"
            android:exported="false" />

        <!-- 情景问候闹钟触发接收器 -->
        <receiver
            android:name=".reminder.GreetingReceiver"
            android:exported="false" />

        <!-- 批量提醒闹钟触发接收器 -->
        <receiver
            android:name=".reminder.BatchReminderTriggerReceiver"
            android:exported="false" />

        <!-- 悬浮提醒 Service：在 App 后台时通过 WindowManager 显示悬浮卡片 -->
        <service
            android:name=".reminder.ReminderFloatingService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- 问候悬浮窗 Service：在 App 后台时通过 WindowManager 显示问候悬浮卡片 -->
        <service
            android:name=".reminder.GreetingFloatingService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- 开机重调度接收器，设备重启后重新注册所有闹钟 -->
        <receiver
            android:name=".reminder.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
